# yaml-language-server: $schema=https://taskfile.dev/schema.json

version: "3"

# Every taskfile under ./taskfiles/ is shipped with the project. This block is
# the switchboard: an include is active when uncommented and inert when
# commented. Enable a feature later by uncommenting its block (and providing the
# files it needs, e.g. terraform/, alembic/). Copier pre-selected the set below
# from the answers you gave when the project was generated.
includes:
  qa:
    taskfile: ./taskfiles/Taskfile.qa.yml
    flatten: true
    vars:
      PROJECT: "{% raw %}{{.PROJECT}}{% endraw %}"
  release: ./taskfiles/Taskfile.release.yml
{% if project_type == 'reflex' %}
  reflex:
    taskfile: ./taskfiles/Taskfile.reflex.yml
    flatten: true
{%- else %}
  # reflex:
  #   taskfile: ./taskfiles/Taskfile.reflex.yml
  #   flatten: true
{%- endif %}
{% if project_type == 'reflex' or include_db %}
  db:
    taskfile: ./taskfiles/Taskfile.db.yml
{%- else %}
  # db:
  #   taskfile: ./taskfiles/Taskfile.db.yml
{%- endif %}
{% if include_docker %}
  docker:
    taskfile: ./taskfiles/Taskfile.docker.yml
    vars:
      IMAGE_NAME: "{% raw %}{{.PROJECT}}{% endraw %}-image"
{%- else %}
  # docker:
  #   taskfile: ./taskfiles/Taskfile.docker.yml
  #   vars:
  #     IMAGE_NAME: "{% raw %}{{.PROJECT}}{% endraw %}-image"
{%- endif %}
{% if include_terraform %}
  dev:
    taskfile: ./taskfiles/Taskfile.terraform.yaml
    vars:
      TF_DIR: "{% raw %}{{.ROOT_DIR}}{% endraw %}/terraform"
      ENVIRONMENT: dev
  prod:
    taskfile: ./taskfiles/Taskfile.terraform.yaml
    vars:
      TF_DIR: "{% raw %}{{.ROOT_DIR}}{% endraw %}/terraform"
      ENVIRONMENT: prod
{%- else %}
  # dev:
  #   taskfile: ./taskfiles/Taskfile.terraform.yaml
  #   vars:
  #     TF_DIR: "{% raw %}{{.ROOT_DIR}}{% endraw %}/terraform"
  #     ENVIRONMENT: dev
  # prod:
  #   taskfile: ./taskfiles/Taskfile.terraform.yaml
  #   vars:
  #     TF_DIR: "{% raw %}{{.ROOT_DIR}}{% endraw %}/terraform"
  #     ENVIRONMENT: prod
{%- endif %}
{% if include_docs %}
  docs:
    taskfile: ./taskfiles/Taskfile.docs.yml
{%- else %}
  # docs:
  #   taskfile: ./taskfiles/Taskfile.docs.yml
{%- endif %}
{% raw %}
silent: true

vars:
  # Derived from the wheel package declared in pyproject.toml, so it always
  # matches the real package name (no template substitution needed here).
  PROJECT:
    sh: awk -F'"' '/^packages = \[/{print $2}' pyproject.toml

tasks:
  default:
    desc: Show available commands
    cmd: task --list

  # ----------------------------------------------------------------------------
  # Project Initialization and Dependency Management
  # ----------------------------------------------------------------------------

  init:
    desc: Initialize project (install python, sync deps, setup pre-commit)
    vars:
      PYTHON_VERSION:
        sh: |
          grep 'requires-python' pyproject.toml | sed -E 's/.*>=?([0-9]+\.[0-9]+).*/\1/'
    cmds:
      - echo "🐍 Installing Python {{.PYTHON_VERSION}}..."
      - uv python install {{.PYTHON_VERSION}}
      - uv python pin {{.PYTHON_VERSION}}
      - echo "📦 Syncing dependencies..."
      - uv sync
      - echo "🔒 Installing pre-commit hooks..."
      - uv tool list | grep -q pre-commit || uv tool install pre-commit
      - git rev-parse --git-dir >/dev/null 2>&1 || git init -b main
      - uv run pre-commit install

  install:
    desc: Install all dependencies (including dev extras)
    cmd: uv sync

  sync:
    desc: Install dependencies using uv
    cmd: uv sync

  clean:
    desc: Clean cache and build artifacts
    ignore_error: true
    cmds:
      - rm -rf __pycache__/ .cache/ .state/ .web/ dist/ build/ coverage.xml .coverage
      - find . -type d -name "__pycache__" -exec rm -rf {} +
      - find . -type f -name "*.pyc" -delete
{% endraw %}